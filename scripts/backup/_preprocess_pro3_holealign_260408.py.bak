import argparse
from pathlib import Path

import cv2
import numpy as np


def _to_uint8_image(img):
    # 디버그 저장용: 다양한 dtype 이미지를 안전하게 uint8로 변환한다.
    if img is None:
        return None
    if img.dtype == np.uint8:
        return img
    if img.dtype == np.bool_:
        return img.astype(np.uint8) * 255
    return np.clip(img, 0, 255).astype(np.uint8)


class StageImageDumper:
    # 처리 순서대로 번호를 붙여 중간 결과 이미지를 저장한다.
    def __init__(self, stage_dir):
        self.stage_dir = Path(stage_dir)
        self.stage_dir.mkdir(parents=True, exist_ok=True)
        self.step = 1

    def save(self, stage_name, image):
        if image is None:
            return None
        out = _to_uint8_image(image)
        out_path = self.stage_dir / f"{self.step:02d}_{stage_name}.png"
        if not cv2.imwrite(str(out_path), out):
            raise RuntimeError(f"failed_to_write_stage_image: {out_path}")
        self.step += 1
        return out_path



#################### 템플릿 오버레이 미리보기 함수 ####################
'''
템플릿 이미지(template_bgr) 위에 정렬된 grayscale 결과(aligned_gray)를
마스크(aligned_mask) 영역에만 반투명(alpha)으로 합성해 시각화한다.
즉, 정렬 결과가 템플릿과 얼마나 잘 맞는지 빠르게 확인하기 위한 preview 이미지를 만든다.
'''
def overlay_preview(template_bgr, aligned_gray, aligned_mask, alpha=0.45):
    
    # aligned_gray를 BGR로 변환
    proc_bgr = cv2.cvtColor(aligned_gray, cv2.COLOR_GRAY2BGR)

    # template와 aligned를 alpha 비율로 블렌딩
    blended = cv2.addWeighted(template_bgr, 1.0 - alpha, proc_bgr, alpha, 0.0)
    
    # aligned_mask>0 영역에만 블렌딩 결과를 적용
    out = template_bgr.copy()
    mask_bool = aligned_mask > 0
    out[mask_bool] = blended[mask_bool]

    # 최종 overlay 이미지 반환
    return out



#################### 중심 크롭 + 경계 패딩 함수 ####################
'''
지정한 중심점(center)을 기준으로 crop_size만큼 이미지를 크롭한다.
크롭 영역이 원본 이미지 경계를 벗어나면 reflect 패딩(BORDER_REFLECT_101)을 적용해
항상 동일한 크기(crop_size)의 결과 이미지를 반환한다.
'''
def center_crop_with_padding(gray, crop_size=(600, 600), center=None):
    
    h, w = gray.shape
    cw, ch = crop_size

    # center가 없으면 이미지 정중앙을 크롭 중심으로 사용
    if center is None:
        cx = w // 2
        cy = h // 2
    else:
        cx = int(round(center[0]))
        cy = int(round(center[1]))

    # 중심 기준으로 크롭 박스 좌표(x1,y1,x2,y2) 계산
    x1 = cx - cw // 2
    y1 = cy - ch // 2
    x2 = x1 + cw
    y2 = y1 + ch

    # 경계를 벗어난 양만큼 좌/상/우/하 패딩량 계산
    pad_left = max(0, -x1)
    pad_top = max(0, -y1)
    pad_right = max(0, x2 - w)
    pad_bottom = max(0, y2 - h)

    # 필요한 경우 reflect 패딩 적용 후 좌표 보정
    if pad_left or pad_top or pad_right or pad_bottom:
        gray = cv2.copyMakeBorder(
            gray,
            pad_top,
            pad_bottom,
            pad_left,
            pad_right,
            cv2.BORDER_REFLECT_101,
        )
        x1 += pad_left
        x2 += pad_left
        y1 += pad_top
        y2 += pad_top

    # 최종 크롭 영역 반환
    return gray[y1:y2, x1:x2]



#################### 중심을 기준으로 스케일 맞추는 함수 ####################
'''
중심을 고정한 채 이미지를 등방 축소/확대한다.
'''
def scale_about_center(img, center, scale, interpolation, border_mode, border_value=0):
    
    h, w = img.shape[:2]
    matrix = cv2.getRotationMatrix2D(center, 0.0, float(scale))

    return cv2.warpAffine(
        img,
        matrix,
        (w, h),
        flags       =interpolation,
        borderMode  =border_mode,
        borderValue =border_value,
    )



#################### 마스크의 bbox 사이즈 계산 함수 ####################
'''
마스크의 bbox 크기(width, height)를 반환한다.
'''
def mask_bbox_size(mask):

    ys, xs = np.where(mask > 0)

    if xs.size == 0 or ys.size == 0:
        return None
    
    w = int(xs.max() - xs.min() + 1)
    h = int(ys.max() - ys.min() + 1)

    return (w, h)


#################### 외곽 IoU 기반 fallback 회전 함수 ####################
'''
lumen 검출 실패 시 외곽 마스크 IoU로 fallback 회전을 계산한다.
'''
def find_best_rotation_outer_mask(placed_outer_mask, template_outer_mask, center, coarse_step=3.0, fine_step=0.25):
    
    best_angle = 0.0
    best_score = -1.0

    for angle in np.arange(-180.0, 180.0, coarse_step, dtype=np.float32):
        rot = rotate_image(
            placed_outer_mask,
            angle_deg=float(angle),
            center=center,
            interpolation=cv2.INTER_NEAREST,
            border_value=0,
            border_mode=cv2.BORDER_CONSTANT,
        )
        score = iou_score(rot, template_outer_mask)
        if score > best_score:
            best_score = float(score)
            best_angle = float(angle)

    for angle in np.arange(best_angle - coarse_step, best_angle + coarse_step + fine_step, fine_step, dtype=np.float32):
        rot = rotate_image(
            placed_outer_mask,
            angle_deg=float(angle),
            center=center,
            interpolation=cv2.INTER_NEAREST,
            border_value=0,
            border_mode=cv2.BORDER_CONSTANT,
        )
        score = iou_score(rot, template_outer_mask)
        if score > best_score:
            best_score = float(score)
            best_angle = float(angle)

    return best_angle, best_score



#################### IoU 계산 함수 ####################
'''
두 마스크의 IoU 점수를 계산한다.

IoU(Intersection over Union): 
- 예측한 박스(prediction)와 실제 박스(ground truth)의 교집합 영역을 합집합 영역으로 나눈 값
- 0 ~ 1 사이의 값을 가지며, 1에 가까울수록 모델의 예측 정확도가 높음을 의미한다.
'''
def iou_score(mask_a, mask_b):

    a = mask_a > 0
    b = mask_b > 0

    inter = np.logical_and(a, b).sum()
    union = np.logical_or(a, b).sum()

    if union == 0:
        return 0.0
    
    return float(inter / union)



#################### 이미지 회전 함수 ####################
'''
중심(center) 기준으로 이미지를 회전한다.
'''
def rotate_image(img, angle_deg, center, interpolation, border_value=0, border_mode=cv2.BORDER_CONSTANT):
    
    h, w = img.shape[:2]
    matrix = cv2.getRotationMatrix2D(center, angle_deg, 1.0)
    
    return cv2.warpAffine(
        img,
        matrix,
        (w, h),
        flags       =interpolation,
        borderMode  =border_mode,
        borderValue =border_value,
    )



#################### 적절한 회전각을 찾는 함수 ####################
'''
source lumen 마스크를 template lumen 마스크에 가장 잘 맞추는 회전각을 찾는 함수이다.
먼저 빠르게 값을 추려내고,
그 주변을 정확하게(촘촘히) 다시 찾는 coarse-to-fine 회전 탐색 방식
big에 가장 큰 가중치를 둬서 방향 안정성을 높인다.
'''
def find_best_rotation_with_lumen_groups(source_grouped, template_grouped, center, coarse_step=3.0, fine_step=0.25):
    
    # source의 big_mask/small_mask/all_mask를 가져온다.
    t_big = source_grouped["big_mask"]
    t_small = source_grouped["small_mask"]
    t_all = source_grouped["all_mask"]

    # template의 big_mask/small_mask/all_mask를 가져온다.
    ref_big = template_grouped["big_mask"]
    ref_small = template_grouped["small_mask"]
    ref_all = template_grouped["all_mask"]

    def score_at(angle):

        # t_big를 angle 각도로 회전
        rb = rotate_image(
            t_big,
            angle_deg=angle,
            center=center,
            interpolation=cv2.INTER_NEAREST,
            border_value=0,
            border_mode=cv2.BORDER_CONSTANT,
        )

        # t_small을 angle 각도로 회전
        rs = rotate_image(
            t_small,
            angle_deg=angle,
            center=center,
            interpolation=cv2.INTER_NEAREST,
            border_value=0,
            border_mode=cv2.BORDER_CONSTANT,
        )

        # t_all을 angle 각도로 회전
        ra = rotate_image(
            t_all,
            angle_deg=angle,
            center=center,
            interpolation=cv2.INTER_NEAREST,
            border_value=0,
            border_mode=cv2.BORDER_CONSTANT,
        )

        #  회전된 3개 마스크와 템플릿 마스크의 IoU 계산(iou_score)
        s_big = iou_score(rb, ref_big)
        s_small = iou_score(rs, ref_small)
        s_all = iou_score(ra, ref_all)

        # 가중합 점수 계산
        score = 0.55 * s_big + 0.30 * s_small + 0.15 * s_all

        # 점수와 세부 IoU 반환
        return score, s_big, s_small, s_all

    # 최고 후보 best 초기화
    best = {"angle": 0.0, "score": -1.0, "s_big": 0.0, "s_small": 0.0, "s_all": 0.0}

    # -180 ~ 180 범위를 coarse_step(기본 3도)로 훑으며 최고점 갱신
    for angle in np.arange(-180.0, 180.0, coarse_step, dtype=np.float32):
        score, s_big, s_small, s_all = score_at(float(angle))
        if score > best["score"]:
            best = {
                "angle"     : float(angle),
                "score"     : float(score),
                "s_big"     : float(s_big),
                "s_small"   : float(s_small),
                "s_all"     : float(s_all),
            }

    # coarse 최적각 주변만 fine_step(기본 0.25도)로 다시 탐색 (fine search)
    for angle in np.arange(best["angle"] - coarse_step, best["angle"] + coarse_step + fine_step, fine_step, dtype=np.float32):
        score, s_big, s_small, s_all = score_at(float(angle))
        if score > best["score"]:
            best = {
                "angle"     : float(angle),
                "score"     : float(score),
                "s_big"     : float(s_big),
                "s_small"   : float(s_small),
                "s_all"     : float(s_all),
            }

    # 최종 best 결과 반환
    return best



#################### source lumen 탐지 함수 ####################
'''
입력 이미지(source_gray)의 단면 마스크(source_section_mask) 내부에서 lumen 후를 찾고,
여러 blur(블러) + threshold 조합을 시도해,
가장 점수가 좋은 후보 세트를 하나 선택해 반환하는 함수이다.
'''
def detect_source_lumens(source_gray, source_section_mask):

    # 단면 마스크를 침식(erode)해서 내부 영역 inner_section만 남김
    sec_area = max(float(np.count_nonzero(source_section_mask)), 1.0)
    inner_section = cv2.erode(source_section_mask, np.ones((11, 11), np.uint8), iterations=1)

    # 최적 lumen 후보 저장용 best 초기화
    best = None

    # 블러 커널 크기 후보 (31, 25, 35) 순회
    for ksize in [31, 25, 35]:

        # 현재 커널 사이즈(ksize)로 gaussian blur 적용
        blurred = cv2.GaussianBlur(source_gray, (ksize, ksize), 0)
        
        # 단면 내부 픽셀 밝기값만 추출
        vals = blurred[inner_section > 0]

        # 내부 픽셀 개수가 너무 적으면 다음 후보로 넘어감
        if vals.size < 100:
            continue

        # 내부 밝기값에 대해 Otsu threshold 계산
        otsu_thr, _ = cv2.threshold(vals.astype(np.uint8), 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)

        # Otsu 값 주변 오프셋 (0, ±5, ±10) 순회
        for offset in [0, 5, -5, 10, -10]:

            # threshold를 0 ~ 255로 클리핑
            thr = float(np.clip(otsu_thr + offset, 0, 255))

            # 후보 마스크 cand를 0으로 초기화
            cand = np.zeros_like(source_gray, dtype=np.uint8)

            # blurred <= thr 이고 내부 영역인 픽셀만 255로 설정 (어두운 홀 후보)
            cand[(blurred <= thr) & (inner_section > 0)] = 255

            # 모폴로지 연산
            cand = cv2.morphologyEx(cand, cv2.MORPH_OPEN, np.ones((7, 7), np.uint8))        # cv2.MORPH_OPEN으로 작은 노이즈 제거
            cand = cv2.morphologyEx(cand, cv2.MORPH_CLOSE, np.ones((11, 11), np.uint8))     # cv2.MORPH_CLOSE로 작은 틈 메움

            # 1차 lumen 필터링 (extract_lumen_components)
            comps = _extract_lumen_components(
                binary_mask     =cand,
                section_area    =sec_area,
                min_ratio       =0.003,
                max_ratio       =0.30,
                min_circularity =0.55,
            )

            # 2차 lumen 필터링 (lumen이 3개로 검출 시 분할 복원 시도)
            comps = _augment_components_if_merged(
                components      =comps,
                shape           =source_gray.shape,
                section_area    =sec_area,
                min_ratio       =0.003,
                max_ratio       =0.30,
                min_circularity =0.55,
            )

            # _build_hole_group_masks로 top4를 big/small/all 그룹 마스크로 구성 시도
            grouped = _build_hole_group_masks(source_gray.shape, comps)

            # 상위 후보 개수 계산 (최대 4개)
            count_top = min(len(comps), 4)
            # 후보가 0개이면 다음 후보로 넘어감
            if count_top == 0:
                continue
            
            # score 계산용 top 후보 선택
            top = comps[:count_top]

            # top 중 가장 작은 면적
            smallest = float(top[-1]["area"])

            # top 후보들의 평균 circularity
            mean_circ = float(np.mean([x["circularity"] for x in top]))

            gap = 0.0
            
            # 그룹 생성 성공 시 big/small 면적 비율(gap) 계산 
            if grouped is not None:
                gap = float(grouped["big"][1]["area"] / max(grouped["small"][0]["area"], 1.0))

            # 최종 score 계산 (4개 검출을 최우선으로, 그다음 작은 홀까지 안정적으로 남는 후보를 선호한다.)
            score = count_top * 10000.0 + smallest + mean_circ * 100.0 + gap * 50.0

            # 현재 점수가 최고치 이면 best 갱신
            if best is None or score > best["score"]:
                best = {
                    "score": score,
                    "ksize": ksize,
                    "threshold": thr,
                    "components": comps,
                    "grouped": grouped,
                }

    # 끝까지 후보가 없다면 실패 처리
    if best is None:
        return None

    # 최고 후보 best 반환
    return best



#################### 마스크 모멘트 구하는 함수 ####################
'''
이진 마스크의 무게중심을 구한다.
'''
def mask_centroid(mask):
    
    m = cv2.moments(mask)

    if m["m00"] == 0:
        h, w = mask.shape
        return (float(w) * 0.5, float(h) * 0.5)
    
    return (float(m["m10"] / m["m00"]), float(m["m01"] / m["m00"]))



#################### input image를 template 좌표계로 변환하는 함수 ####################
'''
입력(source) 이미지와 마스크를 템플릿 좌표계로 스케일 + 평행이동 정렬 하는 함수이다.
'''
def place_to_template(gray_source, outer_mask, section_mask, template_shape, template_center, scale):
    
    # 템플릿 출력 크기(높이, 너비)를 받는다.
    h_t, w_t = template_shape

    # gray_source 리사이즈
    scaled_gray = cv2.resize(gray_source, None, fx=scale, fy=scale, interpolation=cv2.INTER_CUBIC)
    # 외곽 마스크 리사이즈
    scaled_outer = cv2.resize(outer_mask, None, fx=scale, fy=scale, interpolation=cv2.INTER_NEAREST)
    # 단면 마스크 리사이즈
    scaled_section = cv2.resize(section_mask, None, fx=scale, fy=scale, interpolation=cv2.INTER_NEAREST)

    # 스케일 된 단면 마스크 중심 계산
    src_center = mask_centroid(scaled_section)

    # 템플릿 중심 좌표를 기준으로 이동 거리 계산
    dx = float(template_center[0] - src_center[0])
    dy = float(template_center[1] - src_center[1])
    
    # 2x3 affine 이동 행렬 생성
    matrix = np.float32([[1, 0, dx], [0, 1, dy]])

    # 스케일된 gray를 dx,dy 만큼 이동시켜 템플릿 크기에 배치
    placed_gray = cv2.warpAffine(
        scaled_gray,
        matrix,
        (w_t, h_t),
        flags       =cv2.INTER_CUBIC,
        borderMode  =cv2.BORDER_CONSTANT,
        borderValue =0,
    )

    # 스케일된 외곽 마스크를 dx,dy 만큼 이동시켜 템플릿 크기에 배치
    placed_outer = cv2.warpAffine(
        scaled_outer,
        matrix,
        (w_t, h_t),
        flags=cv2.INTER_NEAREST,
        borderMode=cv2.BORDER_CONSTANT,
        borderValue=0,
    )

    # 스케일된 단면 마스크를 dx,dy 만큼 이동시켜 템플릿 크기에 배치
    placed_section = cv2.warpAffine(
        scaled_section,
        matrix,
        (w_t, h_t),
        flags=cv2.INTER_NEAREST,
        borderMode=cv2.BORDER_CONSTANT,
        borderValue=0,
    )

    return placed_gray, placed_outer, placed_section, dx, dy



#################### gray scale 함수 ####################
'''
컬러 이미지를 gray scale로 변환한다.
'''
def to_grayscale(img):

    if len(img.shape) == 3:
        return cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    
    return img



#################### 메인 전처리 함수 ####################
'''
입력 이미지 1장을 템플릿 기준으로 정렬/회전/크롭/저장 하는 핵심 함수
이 함수는 “한 장 입력 -> 템플릿 기준 정렬/회전 -> 자동 맞춤 스케일 -> 크롭 -> 결과/오버레이 저장”까지 한 번에 처리한다.
'''
def process_one(
    image_path,
    template_model,
    output_dir,
    overlay_dir,
    crop_size,
    alpha,
    scale_adjust,
    save_overlay,
    stage_root_dir=None,
):

    stage_dumper = None
    if stage_root_dir is not None:
        stage_dumper = StageImageDumper(Path(stage_root_dir) / image_path.stem)

    # input img를 읽음    
    img = cv2.imread(str(image_path), cv2.IMREAD_COLOR)
    # input img 읽기 실패 처리
    if img is None:
        return False, "imread_failed"
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_input", img)
    
    # input img gray scale 변환 
    gray = to_grayscale(img)
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_grayscale", gray)

    # source 외곽 성분 추출 (여기서 source은 입력 이미지의 카테터 단면이다.)
    source_outer_info = extract_main_component(gray, foreground="bright")
    # source 외곽 성분 추출 실패 처리
    if source_outer_info is None:
        return False, "source_outer_component_not_found"
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_outer", source_outer_info["mask"])
    
    # source 외곽 마스크를 채워 단면 마스크 생성
    source_section = fill_section_mask(source_outer_info["mask"])
    # source 마스크 채움 실패 처리
    if source_section is None:
        return False, "target_section_mask_not_found"
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_section", source_section)
    
    # source 대비 template 면적 비율로 스케일 계산
    lumen_area = max(float(source_outer_info["area"]), 1.0)
    template_area = max(float(template_model["area"]), 1.0)
    scale = np.sqrt(template_area / lumen_area) * float(scale_adjust)

    # place_to_template로 source를 템플릿 좌표계에 배치(스케일 + 시프트, dx,dy도 함께 받음)
    placed_gray, placed_outer, placed_section, dx, dy = place_to_template(
        gray_source     =gray,
        outer_mask      =source_outer_info["mask"],
        section_mask    =source_section,
        template_shape  =template_model["gray"].shape,
        template_center =template_model["center"],
        scale           =scale,
    )
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_place_to_template_gray", placed_gray)
        stage_dumper.save("pro3_source_place_to_template_outer", placed_outer)
        stage_dumper.save("pro3_source_place_to_template_section", placed_section)

    # input image에서 lumen 탐지
    source_lumen_result = detect_source_lumens(placed_gray, placed_section)
    
    # 템플릿 중심 사용
    center = template_model["center"]

    # lumen 기반 회전 각도 추정 경로
    if source_lumen_result is not None and source_lumen_result.get("grouped") is not None:
        rot = find_best_rotation_with_lumen_groups(
            source_grouped      =source_lumen_result["grouped"],
            template_grouped    =template_model["holes"],
            center              =center,
            coarse_step         =3.0,
            fine_step           =0.25,
        )
        if stage_dumper is not None:
            grouped = source_lumen_result["grouped"]
            stage_dumper.save("pro3_source_detect_source_lumens_big_mask", grouped["big_mask"])
            stage_dumper.save("pro3_source_detect_source_lumens_small_mask", grouped["small_mask"])
            stage_dumper.save("pro3_source_detect_source_lumens_all_mask", grouped["all_mask"])
        best_angle = float(rot["angle"])
        metric_msg = (
            f"hole[ score={rot['score']:.3f}, k={source_lumen_result['ksize']}, thr={source_lumen_result['threshold']:.1f}, "
            f"iou_big={rot['s_big']:.3f}, iou_small={rot['s_small']:.3f}, iou_all={rot['s_all']:.3f} ]"
        )
    # lumen 탐지 실패 시 외곽 IoU 기반 fallback 회전
    else:
        best_angle, outer_iou = find_best_rotation_outer_mask(
            placed_outer_mask       =placed_outer,
            template_outer_mask     =template_model["outer_mask"],
            center                  =center,
            coarse_step             =3.0,
            fine_step               =0.25,
        )
        metric_msg = f"fallback[ score={outer_iou:.3f}, iou_outer={outer_iou:.3f} ]"

    # 배치된 gray를 best_angle로 회전 (오버레이용 정렬 결과 생성)
    aligned_gray = rotate_image(
        placed_gray,
        angle_deg       =best_angle,
        center          =center,
        interpolation   =cv2.INTER_CUBIC,
        border_value    =0,
        border_mode     =cv2.BORDER_CONSTANT,
    )

    # 배치된 section을 best_angle로 회전 (오버레이용 정렬 결과 생성)
    aligned_section = rotate_image(
        placed_section,
        angle_deg       =best_angle,
        center          =center,
        interpolation   =cv2.INTER_NEAREST,
        border_value    =0,
        border_mode     =cv2.BORDER_CONSTANT,
    )
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_rotate_image_aligned_gray", aligned_gray)
        stage_dumper.save("pro3_source_rotate_image_aligned_section", aligned_section)

    # 원본 스케일 이미지도 회전
    original_center = source_outer_info["center"]
    rotated_original = rotate_image(
        gray,
        angle_deg       =best_angle,
        center          =original_center,
        interpolation   =cv2.INTER_CUBIC,
        border_value    =0,
        border_mode     =cv2.BORDER_REFLECT_101,
    )

    # 원본 외곽 마스크 회전
    rotated_outer_original = rotate_image(
        source_outer_info["mask"],
        angle_deg       =best_angle,
        center          =original_center,
        interpolation   =cv2.INTER_NEAREST,
        border_value    =0,
        border_mode     =cv2.BORDER_CONSTANT,
    )
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_rotate_image_rotated_original", rotated_original)
        stage_dumper.save("pro3_source_rotate_image_rotated_outer_original", rotated_outer_original)
    # 단면 마스크 생성
    rotated_section_original = fill_section_mask(rotated_outer_original)
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_fill_section_mask_rotated_section_original", rotated_section_original)

    # crop 안에 단면이 들어오도록 자동 축소 비율(auto_scale) 계산
    auto_scale = 1.0
    crop_w, crop_h = crop_size
    margin = 14

    # 필요 시 원본/섹션을 중심 고정 축소
    if rotated_section_original is not None:
        bbox = mask_bbox_size(rotated_section_original)

        if bbox is not None:
            bw, bh = bbox
            fit_w = (crop_w - 2 * margin) / max(float(bw), 1.0)
            fit_h = (crop_h - 2 * margin) / max(float(bh), 1.0)
            auto_scale = min(1.0, fit_w, fit_h)

            if auto_scale < 0.999:
                rotated_original = scale_about_center(
                    rotated_original,
                    center          =original_center,
                    scale           =auto_scale,
                    interpolation   =cv2.INTER_CUBIC,
                    border_mode     =cv2.BORDER_REFLECT_101,
                    border_value    =0,
                )

                rotated_section_original = scale_about_center(
                    rotated_section_original,
                    center          =original_center,
                    scale           =auto_scale,
                    interpolation   =cv2.INTER_NEAREST,
                    border_mode     =0,
                )
                if stage_dumper is not None:
                    stage_dumper.save("pro3_source_scale_about_center_rotated_original", rotated_original)
                    stage_dumper.save("pro3_source_scale_about_center_rotated_section_original", rotated_section_original)
    
    # 크롭 중심 결정
    crop_center = original_center
    if rotated_section_original is not None:
        crop_center = mask_centroid(rotated_section_original)

    # center_crop_with_padding 실행
    cropped = center_crop_with_padding(
        rotated_original,
        crop_size   =crop_size,
        center      =crop_center,
    )
    if stage_dumper is not None:
        stage_dumper.save("pro3_source_center_crop_with_padding", cropped)

    # 전처리 이미지 저장
    out_path = output_dir / image_path.name
    # 전처리 이미지 저장 실패 처리
    if not cv2.imwrite(str(out_path), cropped):
        return False, "imwrite_processed_failed"
    
    # 오버레이된 이미지 저장 (옵션)
    if save_overlay:
        ov = overlay_preview(
            template_bgr    =template_model["bgr"],
            aligned_gray    =aligned_gray,
            aligned_mask    =aligned_section,
            alpha           =alpha,
        )
        if stage_dumper is not None:
            stage_dumper.save("pro3_source_overlay_preview", ov)

        cx, cy = int(round(center[0])), int(round(center[1]))
        cv2.drawMarker(ov, (cx, cy), (0, 0, 255), markerType=cv2.MARKER_CROSS, markerSize=20, thickness=2)

        ov_path = overlay_dir / f"{image_path.stem}_overlay.png"
        if not cv2.imwrite(str(ov_path), ov):
            return False, "imwrite_overlay_failed"
        
    geom_msg = (
        f"geom[ scale={scale:.4f}, shift=({dx:.1f},{dy:.1f}), "
        f"rot={best_angle:.2f}, fit={auto_scale:.3f} ]"
    )

    # 전처리 성공 시 메세지 반환
    return (
        True, f"ok {geom_msg}\n{metric_msg}"
    )



############### 선정된 4-lumen 후보의 mask를 만드는 함수 ###############
'''
lumen 후보 components에서 상위 4개를 골라서 big/small/all mask를 만들고,
이후 회전 정렬에 사용할 그룹 정보를 반환하는 함수이다.
'''
def _build_hole_group_masks(shape, components):

    # area가 큰 순으로 정렬 후 상위 4개만 선택
    top4 = sorted(components, key=lambda x: x["area"], reverse=True)[:4]
    # 후보가 4개 미만이면 그룹 구성 실패 처리
    if len(top4) < 4:
        return None
    
    
    big = top4[:2]      # 가장 큰 홀 2개를 big 그룹으로 둔다.
    small = top4[2:4]   # 이후 나머지 2개를 small 그룹으로 둔다.

    # big/small/all mask를 모두 0으로 초기화
    big_mask = np.zeros(shape, dtype=np.uint8)
    small_mask = np.zeros(shape, dtype=np.uint8)
    all_mask = np.zeros(shape, dtype=np.uint8)

    # big 2개의 contour를 채워 big_mask 만듦
    cv2.drawContours(
        big_mask, 
        [big[0]["contour"], big[1]["contour"]], 
        -1, 
        255, 
        thickness=cv2.FILLED
        )
    
    # small 2개의 contour를 채워 small_mask 만듦
    cv2.drawContours(
        small_mask, 
        [small[0]["contour"], small[1]["contour"]], 
        -1, 
        255, 
        thickness=cv2.FILLED,
        )
    
    # big 2개 + small 2개를 모두 채워 all_mask 만듦
    cv2.drawContours(
        all_mask, 
        [big[0]["contour"], big[1]["contour"], small[0]["contour"], small[1]["contour"]], 
        -1, 
        255, 
        thickness=cv2.FILLED,
        )

    # big/small/all mask에 대한 정보를 dictionary로 반환
    return {
        "top4"      :top4,          # 가장 큰 면적 순서 상위 4-lumen 후보 리스트
        "big"       :big,           # top4 중 big 2-lumen 리스트
        "small"     :small,         # top4 중 나머지 small 2-lumen 리스트
        "big_mask"  :big_mask,      # big 2-lumen만 채워진 이진 마스크(0, 255)
        "small_mask":small_mask,    # small 2-lumen만 채워진 이진 마스크(0, 255)
        "all_mask"  :all_mask,      # all 4-lumen이 채워진 이진 마스크(0, 255)
        "big_mean"  :float((big[0]["area"] + big[1]["area"]) * 0.5),        # big 2-lumen 면적의 평균값
        "small_mean":float((small[0]["area"] + small[1]["area"]) * 0.5),    # small 2-lumen 면적의 평균값
    }



############### lumen 후보 성분 분리 함수 ###############
'''
붙어서 1개로 검출된 lumen 후보 성분(component)을 픽셀 x좌표 기준으로 2 cluster로 나눠서
2개의 성분 정보 (contour, area, circularity, center)를 반환한다.
분할이 실패하면 None을 반환한다.
'''
def _split_component_into_two(component, shape):

    # 입력 이미지 크기와 동일한 빈 마스크 생성
    comp_mask = np.zeros(shape, dtype=np.uint8)

    # 분할 대상 성분을 마스크에 채워서 그림 (붙어서 1개로 검출된 lumen을 별도 마스크에 분리하는 작업)
    cv2.drawContours(comp_mask, [component["contour"]], -1, 255, thickness=cv2.FILLED)

    # comp_mask > 0 인 모든 픽셀들의 좌표
    ys, xs = np.where(comp_mask > 0)
    # 픽셀 수가 너무 적으면 분할 신뢰도가 낮아 작업 중단
    if xs.size < 200:
        return None
    
    # x축 좌표만 사용해서 k-means 입력 데이터 구성 
    # lumen이 붙는 케이스가 대부분 좌우(x축) 방향으로 붙는 패턴이 많았음 (휴리스틱 기반 데이터 세팅)
    data = xs.reshape(-1, 1).astype(np.float32)

    # k-means 종료 조건 설정
    # max_iter=50  (반복 횟수가 max_iter에 도달하면 종료, 최대 반복 횟수)
    # epsilon=0.2  (클러스터 중심 변화(오차)가 epsilon 이하가 되면 종료)
    criteria = (cv2.TERM_CRITERIA_EPS + cv2.TERM_CRITERIA_MAX_ITER, 50, 0.2)

    # 2개 군집으로 분할 시도
    _, labels, _ = cv2.kmeans(
        data        =data,                   # 클러스터링 할 입력 데이터
        K           =2,                      # 클러스터 개수
        bestLabels  =None,                   # 초기 입력 라벨 (None 이면 OpenCV 내부적으로 시작)
        criteria    =criteria,               # 종료 조건
        attempts    =5,                      # 초기값을 바꿔 5번 실행 후 가장 좋은 결과를 선택
        flags       =cv2.KMEANS_PP_CENTERS   # 초기 중심 설정 방법
        )

    # 클러스터 라벨을 1차원으로 정리
    labels = labels.reshape(-1)

    # 결과 저장 리스트 초기화
    split_components = []

    # 클러스터 0, 1 각각을 독립 성분으로 복원
    for idx in [0, 1]:
        # 클러스터별 임시 마스크 생성
        m = np.zeros(shape, dtype=np.uint8)

        # 해당 클러스터 픽셀만 255로 채움
        sel = labels == idx
        m[ys[sel], xs[sel]] = 255

        # 끊긴 부분을 메워 성분 형태를 안정화
        m = cv2.morphologyEx(m, cv2.MORPH_CLOSE, np.ones((5, 5), np.uint8))

        # 클러스터에서 contour 추출
        contours, _ = cv2.findContours(m, cv2.RETR_EXTERNAL, cv2. CHAIN_APPROX_SIMPLE)
        # contour 없으면 해당 클러스터는 버림
        if not contours:
            continue

        # 가장 큰 contour를 대표로 선택
        cnt = max(contours, key=cv2.contourArea)

        # contour로 이루어진 면적 계산
        area = float(cv2.contourArea(cnt))
        # 비정상 성분 제외
        if area <= 0:
            continue
        
        # contour 둘레 길이 계산
        peri = float(cv2.arcLength(cnt, True))

        # circularity 계산
        circularity = 0.0 if peri == 0 else float(4.0 * np.pi * area / (peri * peri))

        # 중심 좌표 계산을 위한 모멘트를 계산 (면적에 대한 중심을 구함)
        moment = cv2.moments(cnt)
        # 비정상 contour 제외 (0 나누기 방지)
        if moment["m00"] == 0:
            continue
        
        # 모멘트로 contour 중심 좌표 계산
        cx = float(moment["m10"] / moment["m00"])
        cy = float(moment["m01"] / moment["m00"])

        # contour의 핵심 정보를 dictionary로 저장
        split_components.append(
            {
                "contour"       :cnt,
                "area"          :area,
                "circularity"   :circularity,
                "center"        :(cx, cy),
            }
        )

    # 2개의 성분을 얻지 못한다면 실패 처리
    if len(split_components) != 2:
        return None
    
    # 성공 시 2개의 성분 반환
    return split_components



############### lumen 후보 성분 2차 필터링 함수 ###############
'''
lumen 후보가 3개만 잡혔을 때, 1개를 2개로 쪼개서 4개로 복원 시도하는 후처리이다.
'''
def _augment_components_if_merged(components, shape, section_area, min_ratio, max_ratio, min_circularity):

    # lumen 후보 개수가 정확히 3개 일때만 보정 시도
    if len(components) != 3:
        return components
    
    # 가장 마지막 성분을 2개로 분할 시도 (보통 가장 작은 후보, 휴리스틱 기반 알고리즘)
    split = _split_component_into_two(components[-1], shape)

    # 분할 실패 시 원본 그대로 반환
    if split is None:
        return components
    
    merged = components[:2] + split                     # 기존 상위 2개 + 분할된 2개 = 총 4개 후보 구성
    min_area = float(section_area) * float(min_ratio)   # 단면 면적 대비 최소 허용 범위 계산 [단위: 픽셀(px)]
    max_area = float(section_area) * float(max_ratio)   # 단면 면적 대비 최대 허용 범위 계산 [단위: 픽셀(px)]

    filtered = []
    # 4개의 lumen 후보 순회하며 재검토
    for comp in merged:
        # min_area, max_area 범위를 벗어나면 제외
        if not (min_area <= comp["area"] <= max_area):
            continue
        # circularity 기준보다 낮으면 제외 (약간 완화된 0.90 배수)
        if comp["circularity"] < float(min_circularity) * 0.90:
            continue
        # 통과한 후보를 리스트에 추가
        filtered.append(comp)

    # 면적이 큰 순으로 정렬 (내림차순)
    filtered.sort(key=lambda x: x["area"], reverse=True)

    # 최종 보정된 후보 리스트 반환
    return filtered



############### lumen 후보 성분 1차 필터링 함수 ###############
'''
이진 홀 후보 마스크(binary mask)들의 contour를 찾고,
면적 비율 + 원형도 조건으로 걸러서,
lumen 후보 정보 (contour, area, circularity, center) 리스트를 반환한다.
'''
def _extract_lumen_components(binary_mask, section_area, min_ratio, max_ratio, min_circularity):

    # lumen 후보들의 가장 바깥 contour를 추출한다. (cv2.RETR_EXTERNAL)
    contours, _ = cv2.findContours(binary_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    rows = []                                           # 통과한 후보들을 저장할 리스트 초기화
    min_area = float(section_area) * float(min_ratio)   # 단면 면적(section_area) 대비 허용 최소 면적 계산 [단위: 픽셀(px)]
    max_area = float(section_area) * float(max_ratio)   # 단면 면적(section_area) 대비 허용 최대 면적 계산 [단위: 픽셀(px)]

    # 모든 contour 후보들을 순회
    for cnt in contours:
        # 현재 contour 면적 계산
        area = float(cv2.contourArea(cnt))      

        # area 값이 min_area, max_area 범위를 벗어나면 제외
        if area < min_area or area > max_area:
            continue
        
        # 현재 contour 둘레 길이 계산
        peri = float(cv2.arcLength(cnt, True))

        # circularity 계산 (원에 가까울 수록 값이 1에 가깝다.)
        circularity = 0.0 if peri == 0 else float(4.0 * np.pi * area / (peri * peri))   # 4πA / P²

        # min_circularity 보다 작으면 제외
        if circularity < float(min_circularity):
            continue
        
        # 중심 좌표 계산을 위한 모멘트를 구한다. (면적에 대한 중심을 구함)
        m = cv2.moments(cnt)

        # 비정상 contour 제외 (0 나누기 방지)
        if m["m00"] == 0:
            continue
        
        # 모멘트로 contour 중심 좌표 계산
        cx = float(m["m10"] / m["m00"])
        cy = float(m["m01"] / m["m00"])

        # 현재 contour의 핵심 정보를 dictionary로 rows에 추가
        rows.append(
            {
                "contour":     cnt,             # 현재 후보 성분의 가장 바깥 윤곽선
                "area":         area,           # 윤곽선으로 이루어진 면적
                "circularity":  circularity,    # 원형도 (원형에 가까울수록 값이 1에 가깝다.)
                "center":       (cx, cy),       # 윤곽선으로 이루어진 면적의 중심 좌표
            }
        )
    
    # 후보 성분들을 면적이 큰 순서부터 정렬 (내림차순)
    rows.sort(key=lambda x: x["area"], reverse=True)

    # lumen 후보 리스트 반환
    return rows



############### 템플릿 이미지의 lumen 탐지 함수 ###############
'''
템플릿 이미지에서 lumen(홀) 후보를 여러 threshold로 시도해 가장 좋은 4개 홀 그룹을 고르는 함수이다.
'''
def detect_template_holes(template_gray, template_section_mask):

    # 단면 마스크의 면적(픽셀 수)을 구한다.
    sec_area = max(float(np.count_nonzero(template_section_mask)), 1.0)     # 최소 1.0을 보장 (0 나눗셈 방지용)
    # 강한 블러로 작은 잡음을 줄여 홀 검출을 안정화한다.
    blurred = cv2.GaussianBlur(template_gray, (31, 31), 0)

    best = None
    # 여러 고임계값을 순회하며 후보 마스크를 만든다.
    for thr in [245, 242, 240, 238, 235, 232]:
        cand = np.zeros_like(template_gray, dtype=np.uint8)             # lumen 후보 이진 마스크를 0으로 초기화
        cand[(blurred >= thr) & (template_section_mask > 0)] = 255      # 단면 내부에서 밝기 조건을 만족하는 픽셀만 255로 표시

        # 모폴로지 연산
        cand = cv2.morphologyEx(cand, cv2.MORPH_OPEN, np.ones((5,5), np.uint8))     # 작은 점 노이즈 제거
        cand = cv2.morphologyEx(cand, cv2.MORPH_CLOSE, np.ones((9,9), np.uint8))    # 작은 틈/끊김 메움.

        # 면적 비율, 원형도 조건으로 lumen 성분 후보들을 추출한다. (1차 필터링)
        comps = _extract_lumen_components(
            binary_mask     =cand,
            section_area    = sec_area,
            min_ratio       =0.005,
            max_ratio       =0.28,
            min_circularity =0.55,
        )

        # 붙어서 검출된 경우, 분할해서 4개에 가깝게 복원 시도 (2차 필터링)
        comps = _augment_components_if_merged(
            components      =comps,
            shape           =template_gray.shape,
            section_area    =sec_area,
            min_ratio       =0.005,
            max_ratio       =0.28,
            min_circularity =0.55,
        )

        # 상위 4개를 big/small 그룹 마스크로 구성한다.
        grouped = _build_hole_group_masks(template_gray.shape, comps)
        # 아직 4개의 그룹이 안만들어지면, 현재까지 개수가 더 좋은 후보만 기록하고 다음 threshold로 이동
        if grouped is None:
            if best is None or len(comps) > best["count"]:
                best = {"count": len(comps), "thr": thr, "grouped": None}
            continue
        
        # big과 small 사이 면적 분리도(비율) 계산
        gap = grouped["big"][1]["area"] / max(grouped["small"][0]["area"], 1.0)
        # 유효 그룹(4-lumen)을 우선시키기 위해 큰 상수 + gap 점수 사용
        score = 1000.0 + gap
        # 최고 점수 후보 갱신
        if best is None or score > best.get("score", -1e9):
            best = {"count": len(comps), "thr": thr, "grouped": grouped, "score": score}
        
    # 최종적으로 유효한 lumen 그룹을 못 찾으면 실패 처리
    if best is None or best.get("grouped") is None:
        raise RuntimeError("template_hole_detection_failed")
    
    # 선정된 최종 그룹 결과 가져오기
    out = best["grouped"]
    # 어떤 threshold에서 뽑혔는지 기록
    out["threshold"] = best["thr"]

    # 최종 템플릿 lumen 정보 반환
    return out



############### 외곽 마스크 채우기 함수 ###############
'''
extract_main_component로 얻은 외곽 마스크에서 가장 큰 외곽 contours를 찾아
내부를 꽉 채운 "단면 전체(section) 마스크"를 만든다.
'''
def fill_section_mask(outer_mask):

    # 외곽 마스크의 가장 바깥 contour(윤곽)들만 검출한다.
    contours, _ = cv2.findContours(outer_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    # contour가 하나도 없는 경우 실패 처리
    if not contours:
        return None
    
    c = max(contours, key=cv2.contourArea)                          # 여러 contour 중 면적이 가장 큰 contour 하나를 대표 단면으로 선택
    filled = np.zeros_like(outer_mask, dtype=np.uint8)               # 외곽 마스크를 0으로 초기화
    cv2.drawContours(filled, [c], -1, 255, thickness=cv2.FILLED)    # 선택한 contour 내부를 전부 255로 채움

    # 단면 전체가 채워진 이진 마스크를 반환
    return filled   



############### 카테터 대표 외곽 성분 추출 함수 ###############
'''
템플릿 이미지에서 카테터의 대표 외곽 성분 1개를 선택해서,
이후 정렬에 필요한 mask / center / bbox / area 를 반환하는 함수이다.
즉, 전체 이미지에서 카테터 단면(외곽)으로 보이는 대표 성분을 찾고, 주요 정보를 반환하는 함수이다.
'''
def extract_main_component(gray, foreground="bright"):

    # 노이즈를 줄여 이진화가 안정적으로 되도록 만든다.
    blur = cv2.GaussianBlur(gray, (5,5), 0)
    # foreground == "bright"이면, 일반 이진화 (THRESH_BINARY + OTSU)
    if foreground == "bright":
        _, binary = cv2.threshold(blur, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    # 그 이외의 경우, 반전 이진화 (THRESH_BINARY_INV + OTSU)
    else:
        _, binary = cv2.threshold(blur, 0, 255, cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    
    # 모폴로지 연산 (Morphology)
    kernel = np.ones((3,3), np.uint8)                             # 모폴로지 연산용 커널(3X3)을 만든다. 
    binary = cv2.morphologyEx(binary, cv2.MORPH_OPEN, kernel)     # 작은 흰색 잡음을 제거한다.
    binary = cv2.morphologyEx(binary, cv2.MORPH_CLOSE, kernel)    # 작은 틈/구멍을 메워 성분을 더 매끈하게 만든다.

    # 이진 이미지의 연결 성분들을 추출한다.
    # num_labels: 성분 수, labels: 픽셀별 라벨, stats: bbox/area, centroids: 중심
    num_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(binary, connectivity=8)
    # 배경 이외 유효 성분이 없으면 실패 처리
    if num_labels <= 1:
        return None
    
    h, w = gray.shape                                           # 이미지 크기 획득
    img_center = np.array([w*0.5, h*0.5], dtype=np.float32)     # 이미지 중심 좌표 계산
    diag = max(float(np.hypot(w,h)), 1.0)                       # 거리 정규화를 위한 이미지의 대각선 길이 계산 (sqrt(w^2 + h^2))

    best_idx = None
    best_score = -1.0
    # 배경(0)을 제외한 성분들을 순회
    for idx in range(1, num_labels):
        area = int(stats[idx, cv2.CC_STAT_AREA])                # 현재 성분의 면적을 가져옴 [단위: 픽셀(px)]

        # 너무 작은 성분은 노이즈로 판단하고 제외한다. (1차 필터링)
        min_area = max(100, int(h * w * 1e-4))                  # 최소 면적 임계값 (이미지의 0.01%)
        if area < min_area:
            continue

        c = centroids[idx].astype(np.float32)                   # 현재 성분 중심 좌표 획득
        dist = float(np.linalg.norm(c - img_center) / diag)     # 이미지 중심과 거리를 정규화해서 계산
        score = float(area)*(1.5 - min(dist, 1.2))              # 면적이 크고 중심에 가까운 성분일수록 높은 점수를 주는 방식

        # 최고 score 갱신
        if score > best_score:
            best_score = score
            best_idx = idx
    
    # 선정된 best_idx가 존재하지 않는다면 실패 처리
    if best_idx is None:
        return None
    
    # 전체 이미지를 0으로 두고, 카테터 단면 외곽 성분만 255로 채워 마스크를 추출하는 작업
    mask = np.zeros_like(gray, dtype=np.uint8)          # 이미지 전체 크기의 마스크를 0으로 초기화
    mask[labels == best_idx] = 255                      # best_idx 성분만 255로 채움

    # 전체 이미지에서 선택된 카테터 단면 연결성분을 감싸는 bounding box의 정보
    x    =int(stats[best_idx, cv2.CC_STAT_LEFT])        # 선택 성분 bounding box의 왼쪽 x 좌표
    y    =int(stats[best_idx, cv2.CC_STAT_TOP])         # 선택 성분 bounding box의 위쪽 y 좌표
    bw   =int(stats[best_idx, cv2.CC_STAT_WIDTH])       # bounding box의 너비
    bh   =int(stats[best_idx, cv2.CC_STAT_HEIGHT])      # bounding box의 높이
    area =int(stats[best_idx, cv2.CC_STAT_AREA])        # 선택 성분의 면적 (픽셀 개수)
    cx, cy = centroids[best_idx]                        # 선택 성분의 중심점(centroid) 좌표

    # 주요 성분에 대한 정보를 dictionary 형태로 반환
    return {
        "mask"   :mask,
        "center" :(float(cx), float(cy)),
        "bbox"   :(x, y, bw, bh),
        "area"   :area,
    }



############### template model 만들기 함수 ###############
'''
해당 함수는 템플릿 이미지의 정보(마스크, 홀)를 추출해서,
process_one()에 넘겨주기 위한 템플릿 정보 묶음 template_model을 만드는 함수이다.
즉, 템플릿에서 정렬 기준(중심, 면적, 외곽, 홀 구조)을 한 번에 계산하여 묶어두는 준비 함수이다.
'''
def prepare_template(template_path, stage_root_dir=None):

    stage_dumper = None
    if stage_root_dir is not None:
        stage_dumper = StageImageDumper(Path(stage_root_dir) / "template")

    # 템플릿 파일을 컬러(BGR)로 읽는다.
    template_bgr = cv2.imread(str(template_path), cv2.IMREAD_COLOR)     
    # 템플릿 이미지 로드 실패 여부 검사
    if template_bgr is None:
        raise RuntimeError(f"Failed to read template! ({template_path})")
    if stage_dumper is not None:
        stage_dumper.save("pro3_prepare_template", template_bgr)
    
    # 템플릿 컬러 이미지를 gray scale로 변환
    template_gray = cv2.cvtColor(template_bgr, cv2.COLOR_BGR2GRAY)
    if stage_dumper is not None:
        stage_dumper.save("pro3_prepare_template_grayscale", template_gray)
    # 템플릿에서 카테터 외곽(주요 성분)을 추출, foreground="dark"는 어두운 영역 대상이라는 의미
    template_outer_info = extract_main_component(template_gray, foreground="dark")
    # 외곽 추출 실패 여부 검사
    if template_outer_info is None:
        raise RuntimeError("Template output component not found!")
    if stage_dumper is not None:
        stage_dumper.save("pro3_prepare_template_outer", template_outer_info["mask"])
    
    # 외곽 마스크를 채워서 단면 전체 영역 마스크를 만든다.
    template_section = fill_section_mask(template_outer_info["mask"])
    # 단면 마스크 생성 실패 여부 검사
    if template_section is None:
        raise RuntimeError("Template section mask not found!")
    if stage_dumper is not None:
        stage_dumper.save("pro3_prepare_template_section", template_section)
    
    # 템플릿 내부 홀(lumen)들을 검출해 정렬 기준 정보를 만든다.
    template_holes = detect_template_holes(template_gray, template_section)
    if stage_dumper is not None:
        stage_dumper.save("pro3_prepare_template_holes_big_mask", template_holes["big_mask"])
        stage_dumper.save("pro3_prepare_template_holes_small_mask", template_holes["small_mask"])
        stage_dumper.save("pro3_prepare_template_holes_all_mask", template_holes["all_mask"])

    # template model을 dictionary로 반환
    return {
        "bgr"           : template_bgr,                     # 원본 컬러 템플릿
        "gray"          : template_gray,                    # gray scale 템플릿
        "outer_mask"    : template_outer_info["mask"],      # 외곽 마스크
        "section_mask"  : template_section,                 # 단면 전체 마스크
        "center"        : template_outer_info["center"],    # 외곽 중심점
        "area"          : template_outer_info["area"],      # 외곽 면적
        "holes"         : template_holes,                   # 홀 검출 결과
    }


def run_preprocess(
    input_dir,
    pattern,
    template_path,
    output_dir,
    overlay_dir,
    crop_size,
    alpha,
    scale_adjust,
    save_overlay,
    stage_dir,
    save_stage_images,
):
    
    # input_dir과 template_path 경로에 파일이 존재하지 않는 경우 예외처리
    if not input_dir.exists():
        raise FileNotFoundError(f"input dir not found: {input_dir}")
    if not template_path.exists():
        raise FileNotFoundError(f"template dir not found: {template_path}")
    
    # output_dir 경로에 결과 저장 폴더 만듬
    output_dir.mkdir(parents=True, exist_ok=True)
    
    # save_overlay == True 이면, overlay_dir 경로에 결과 저장 폴더 만듬
    if save_overlay:
        overlay_dir.mkdir(parents=True, exist_ok=True)
    if save_stage_images:
        stage_dir.mkdir(parents=True, exist_ok=True)

    files=sorted(input_dir.glob(pattern))
    total=len(files)

    # 템플릿 이미지 준비
    template_model = prepare_template(
        template_path,
        stage_root_dir=stage_dir if save_stage_images else None,
    )

    # 출력 메시지
    print(f"=============== 전처리 시작 (template registration + big/small lumen split) ===============")
    print(f"이미지 개수:  {total}장")
    print(f"카테터 타입:  pro3 (4-lumen)")
    print(f"input:     {input_dir} ({pattern})")
    print(f"template:  {template_path}")
    print(f"output:    {output_dir}")
    if save_overlay: print(f"overlay:   {overlay_dir}")
    if save_stage_images: print(f"stages:    {stage_dir}")
    print(f"~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~")


    failures = []
    for idx, path in enumerate(files, start=1):
        ok, msg=process_one(
            image_path=path,
            template_model=template_model,
            output_dir=output_dir,
            overlay_dir=overlay_dir,
            crop_size=crop_size,
            alpha=alpha,
            scale_adjust=scale_adjust,
            save_overlay=save_overlay,
            stage_root_dir=stage_dir if save_stage_images else None,
        )

        if ok:
            print(f"[{idx}/{total}] OK    {path.name:<18}")
            print(f"{msg}\n")
        else:
            failures.append((path.name, msg))
            print(f"[{idx}/{total}] FAIL  {path.name:<18}")
            print(f"{msg}\n")
  
    print(f"==================================== 전처리 완료 ===================================")
    if failures:
        print(f"완료 (실패 {len(failures)} 건)")
        for name, msg in failures[:10]:
            print(f"  - {name}: {msg}")
    else:
        print("완료! 모든 이미지를 템플릿 기준으로 정렬했습니다.")


def main():
    parser = argparse.ArgumentParser(
        description="pro3 전처리: 1) Gray scale -> 2) Template Registration(중심+회전) -> 3) Crop"
    )
    parser.add_argument(
        "--input-dir",
        type=Path,
        default=Path("/home/hjj747/catheter-defect-inspection/data/raw/targets/pro_3"),
        help="input data 폴더 경로",
    )
    parser.add_argument(
        "--pattern",
        type=str,
        default="*.png",
        help="파일 확장자(e.g. *.png, *BMP)",
    )
    parser.add_argument(
        "--template",
        type=Path,
        default=Path("/home/hjj747/catheter-defect-inspection/data/raw/templates/pro_3_endpoint.png"),
        help="기준 템플릿 이미지 경로",
    )
    parser.add_argument(
        "--output-dir",
        type=Path,
        default=Path("/home/hjj747/catheter-defect-inspection/data/processed/processed_images/pro3_holealign"),
        help="전처리 결과 저장 폴더 경로",
    )
    parser.add_argument(
        "--overlay-dir",
        type=Path,
        default=Path("/home/hjj747/catheter-defect-inspection/data/processed/overlay_images/pro3_holealign"),
        help="템플릿 오버레이 결과 저장 폴더 경로",
    )
    parser.add_argument(
        "--crop-size",
        nargs=2,
        type=int,
        default=(600, 600),
        metavar=("W", "H"),
        help="최종 크롭 사이즈",
    )
    parser.add_argument(
        "--alpha",
        type=float,
        default=0.45,
        help="오버레이 투명도 (0~1)",
    )
    parser.add_argument(
        "--scale-adjust",
        type=float,
        default=1.0,
        help="자동 스케일 보정 배율",
    )
    parser.add_argument(
        "--no-overlay",
        action="store_true",
        help="오버레이 결과 저장 비활성화",
    )
    parser.add_argument(
        "--stage-dir",
        type=Path,
        default=Path("/home/hjj747/catheter-defect-inspection/data/processed/stage_images/pro3_holealign"),
        help="전처리 중간 결과 이미지 저장 폴더 경로",
    )
    parser.add_argument(
        "--no-stage-images",
        action="store_true",
        help="전처리 중간 결과 이미지 저장 비활성화",
    )
    
    args = parser.parse_args()

    run_preprocess(
        input_dir       =args.input_dir,            # input image 저장 경로
        pattern         =args.pattern,              # 파일 확장자 타입
        template_path   =args.template,             # 기준 템플릿 경로
        output_dir      =args.output_dir,           # output image 저장 경로
        overlay_dir     =args.overlay_dir,          # overlay output image 저장 경로
        crop_size       =tuple(args.crop_size),     # 최종 크롭 사이즈
        alpha           =args.alpha,                # 오버레이 시 투명도
        scale_adjust    =args.scale_adjust,         # 자동 스케일 보정 배율
        save_overlay    =not args.no_overlay,       # 오버레이 결과 저장 비활성화
        stage_dir       =args.stage_dir,            # 전처리 중간 결과 이미지 저장 경로
        save_stage_images=not args.no_stage_images, # 전처리 중간 결과 이미지 저장 비활성화
    )




if __name__ == "__main__":
    main()
